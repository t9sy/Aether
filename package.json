{
  "name": "aether",
  "version": "1.0.0",
  "description": "Aether Browser — A modern, themeable desktop browser built with Electron & React.",
  "author": "t9sy",
  "homepage": "https://github.com/t9sy/aether",
  "repository": {
    "type": "git",
    "url": "https://github.com/t9sy/aether"
  },
  "main": "dist/main/main.js",
  "scripts": {
    "build:renderer": "webpack --config webpack.config.js",
    "build:main": "tsc -p tsconfig.main.json",
    "build": "bun run build:renderer && bun run build:main",
    "dev": "bun run build && electron .",
    "start": "electron .",
    "dist": "bun run build && electron-builder --linux",
    "dist:win": "bun run build && electron-builder --win",
    "dist:linux": "bun run build && electron-builder --linux"
  },
  "build": {
    "appId": "com.aether.browser",
    "productName": "Aether",
    "icon": "build/icon.png",
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "signAndEditExecutable": false
    },
    "linux": {
      "target": "AppImage",
      "category": "Network",
      "icon": "build/icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.png"
    }
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "css-loader": "^7.1.2",
    "electron": "^33.2.0",
    "electron-builder": "^26.8.1",
    "html-webpack-plugin": "^5.6.3",
    "postcss": "^8.4.49",
    "postcss-loader": "^8.1.1",
    "style-loader": "^4.0.0",
    "tailwindcss": "^3.4.16",
    "ts-loader": "^9.5.1",
    "typescript": "^5.7.2",
    "webpack": "^5.97.1",
    "webpack-cli": "^6.0.1"
  }
}
