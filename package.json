{
  "name": "aura-browser",
  "version": "1.0.0",
  "description": "Aura Browser — A modern, themeable desktop browser built with Electron & React.",
  "main": "dist/main/main.js",
  "scripts": {
    "build:renderer": "webpack --config webpack.config.js",
    "build:main": "tsc -p tsconfig.main.json",
    "build": "bun run build:renderer && bun run build:main",
    "dev": "bun run build && electron .",
    "start": "electron ."
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "css-loader": "^7.1.2",
    "electron": "^33.2.0",
    "html-webpack-plugin": "^5.6.3",
    "postcss": "^8.4.49",
    "postcss-loader": "^8.1.1",
    "style-loader": "^4.0.0",
    "tailwindcss": "^3.4.16",
    "ts-loader": "^9.5.1",
    "typescript": "^5.7.2",
    "webpack": "^5.97.1",
    "webpack-cli": "^6.0.1"
  }
}
